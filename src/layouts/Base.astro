---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  structuredData?: object | object[];
  tags?: string[];
  theme?: 'light' | 'dark';
}

const { title, description, ogImage, ogType, structuredData, tags, theme = 'light' } = Astro.props;
---
<!doctype html>
<html lang="en" class={theme === 'dark' ? 'dark' : ''} data-theme={theme}>
  <head>
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      tags={tags}
      structuredData={structuredData}
    />
  </head>
  <body class:list={[
    'min-h-screen antialiased grain',
    theme === 'dark'
      ? 'bg-[color:var(--color-ink)] text-[color:var(--color-cream)]'
      : 'bg-[color:var(--color-cream)] text-[color:var(--color-ink)]'
  ]}>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-[color:var(--color-ink)] focus:text-[color:var(--color-cream)] focus:px-4 focus:py-2 focus:text-sm">Skip to content</a>

    <header class="relative z-20">
      <nav class="max-w-7xl mx-auto px-6 md:px-10 pt-8 pb-4 flex items-center justify-between">
        <a href="/" class="font-display italic text-2xl tracking-tight">Meridian</a>
        <div class="hidden md:flex items-center gap-10 text-sm">
          <a href="/" class="hover:text-[color:var(--color-ember)] transition">Home</a>
          <a href="/about" class="hover:text-[color:var(--color-ember)] transition">Our Story</a>
          <a href="/#waitlist" class="inline-flex items-center gap-2 border border-current/30 rounded-full px-4 py-1.5 text-xs uppercase tracking-[0.2em] hover:bg-[color:var(--color-ember)] hover:text-[color:var(--color-cream)] hover:border-[color:var(--color-ember)] transition">Join Waitlist</a>
        </div>
        <a href="/#waitlist" class="md:hidden text-xs uppercase tracking-[0.2em] border border-current/30 rounded-full px-3 py-1.5">Waitlist</a>
      </nav>
    </header>

    <main id="main" class="relative z-10">
      <slot />
    </main>

    <footer class="relative z-10 border-t border-current/10 mt-24">
      <div class="max-w-7xl mx-auto px-6 md:px-10 py-12 grid grid-cols-1 md:grid-cols-3 gap-8 text-sm">
        <div>
          <p class="font-display italic text-xl mb-3">Meridian</p>
          <p class="opacity-70 max-w-xs leading-relaxed">Coffee at the intersection of origin and craft. Single-origin beans, sourced and roasted with intention.</p>
        </div>
        <div>
          <p class="uppercase tracking-[0.25em] text-xs opacity-60 mb-3">Explore</p>
          <ul class="space-y-2">
            <li><a href="/" class="hover:text-[color:var(--color-ember)] transition">Home</a></li>
            <li><a href="/about" class="hover:text-[color:var(--color-ember)] transition">Our Story</a></li>
            <li><a href="/#waitlist" class="hover:text-[color:var(--color-ember)] transition">Join the Waitlist</a></li>
          </ul>
        </div>
        <div>
          <p class="uppercase tracking-[0.25em] text-xs opacity-60 mb-3">Stay Close</p>
          <p class="opacity-70 leading-relaxed">Sign up to receive early access, origin dispatches, and first pours from our launch lineup.</p>
          <a href="/#waitlist" class="inline-block mt-3 text-[color:var(--color-ember)] underline underline-offset-4 hover:no-underline">Reserve your seat →</a>
        </div>
      </div>
      <div class="border-t border-current/10">
        <div class="max-w-7xl mx-auto px-6 md:px-10 py-6 flex flex-col md:flex-row items-center justify-between text-xs opacity-60 gap-2">
          <p>© {new Date().getFullYear()} Meridian Coffee. All rights reserved.</p>
          <p class="font-display italic">— Coffee at the Intersection of Origin and Craft —</p>
        </div>
      </div>
    </footer>
  </body>
</html>
