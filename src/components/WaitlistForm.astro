---
interface Props {
  theme?: 'light' | 'dark';
  compact?: boolean;
}
const { theme = 'light', compact = false } = Astro.props;
---
<form id="waitlist-form" class:list={['w-full', compact ? 'max-w-md' : 'max-w-xl']} data-theme={theme}>
  <div class="flex flex-col sm:flex-row gap-3">
    <label for="waitlist-email" class="sr-only">Email address</label>
    <input
      id="waitlist-email"
      type="email"
      name="email"
      required
      autocomplete="email"
      placeholder="your@email.com"
      class="flex-1 bg-transparent border border-current/30 rounded-full px-5 py-3.5 text-base placeholder-current/50 focus:outline-none focus:border-[color:var(--color-ember)] focus:ring-2 focus:ring-[color:var(--color-ember)]/30 transition"
    />
    <button
      type="submit"
      class="inline-flex items-center justify-center gap-2 bg-[color:var(--color-ember)] text-[color:var(--color-cream)] rounded-full px-7 py-3.5 text-sm uppercase tracking-[0.2em] font-medium hover:bg-[color:var(--color-ink)] hover:text-[color:var(--color-cream)] transition whitespace-nowrap"
    >
      <span class="btn-label">Reserve Seat</span>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
  <p id="waitlist-msg" class="mt-3 text-sm opacity-0 transition-opacity duration-300" aria-live="polite"></p>
  <p class="mt-2 text-xs opacity-50">No spam. Unsubscribe anytime. We send dispatches only when we have something real to share.</p>
</form>

<script>
  import { supabase } from '../lib/supabase';

  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const msg  = document.getElementById('waitlist-msg') as HTMLParagraphElement | null;
  const btn  = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  const label = btn?.querySelector('.btn-label') as HTMLSpanElement | null;

  function show(text: string, tone: 'ok' | 'err' | 'info') {
    if (!msg) return;
    msg.textContent = text;
    msg.classList.remove('opacity-0');
    msg.style.color = tone === 'err' ? '#c7462a' : tone === 'ok' ? '#1a1411' : '';
    msg.style.opacity = '1';
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const email = String(fd.get('email') || '').trim().toLowerCase();
    if (!email || !/^\S+@\S+\.\S+$/.test(email)) {
      show('Please enter a valid email.', 'err');
      return;
    }
    if (btn) btn.disabled = true;
    if (label) label.textContent = 'Saving…';

    try {
      const { error } = await supabase
        .from('meridian_waitlist')
        .insert({ email, source: 'homepage', user_agent: navigator.userAgent.slice(0, 300) });

      if (error) {
        if (error.code === '23505') {
          window.location.href = '/thanks';
          return;
        }
        show('Something went wrong. Try again in a moment.', 'err');
        if (btn) btn.disabled = false;
        if (label) label.textContent = 'Reserve Seat';
        return;
      }

      window.location.href = '/thanks';
    } catch {
      show('Network error. Please try again.', 'err');
      if (btn) btn.disabled = false;
      if (label) label.textContent = 'Reserve Seat';
    }
  });
</script>
