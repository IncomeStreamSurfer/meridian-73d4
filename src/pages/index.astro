---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Inter:wght@300;400;500;600&display=swap" />
    <title>Meridian | Specialty Coffee, Coming Soon</title>
    <meta name="description" content="Meridian is a specialty coffee brand rooted in origin and craft. Something exceptional is brewing." />
  </head>
  <body class="min-h-screen bg-[color:var(--color-cream)] text-[color:var(--color-ink)] grain overflow-hidden">
    <main class="relative z-10 min-h-screen flex flex-col items-center justify-center px-6 text-center">
      <div class="reveal-up">
        <p class="text-xs uppercase tracking-[0.4em] text-[color:var(--color-mist)] mb-8 pulse-soft">— Est. Soon —</p>
        <h1 class="text-6xl md:text-8xl font-display italic leading-[0.95] mb-6">Meridian</h1>
        <div class="w-12 h-px bg-[color:var(--color-ember)] mx-auto mb-6"></div>
        <p class="text-lg md:text-xl text-[color:var(--color-ink-soft)] max-w-md mx-auto">Something exceptional is brewing.</p>
        <p class="mt-10 text-sm text-[color:var(--color-mist)] uppercase tracking-widest pulse-soft">Building the site…</p>
      </div>
    </main>
  </body>
</html>
