---
import Base from '../layouts/Base.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const title = 'Meridian | Specialty Coffee, Coming Soon';
const description = 'Meridian is a specialty coffee brand rooted in origin and craft. Join the waitlist for early access, exclusive drops, and stories from the source.';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://meridian-73d4.vercel.app';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Meridian',
    url: siteUrl,
    logo: `${siteUrl}/logo.svg`,
    description: 'A specialty coffee brand built for the curious palate — sourcing single-origin beans from the world’s most distinctive growing regions.',
    sameAs: []
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Meridian',
    url: siteUrl,
    description: 'Coffee at the Intersection of Origin and Craft'
  }
];
---
<Base
  title={title}
  description={description}
  structuredData={structuredData}
  tags={["specialty coffee brand","single origin coffee","craft coffee roaster","premium coffee beans","artisan coffee subscription"]}
>
  <section class="relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-10 pt-20 md:pt-28 pb-24 md:pb-32 grid md:grid-cols-12 gap-12 items-end">
      <div class="md:col-span-7 reveal-up">
        <p class="flex items-center gap-3 text-xs uppercase tracking-[0.4em] opacity-60 mb-8">
          <span class="w-8 h-px bg-current"></span>
          Est. Soon — Pre-launch
        </p>
        <h1 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl italic leading-[0.95] tracking-tight">
          Something
          <span class="block">exceptional</span>
          <span class="block">is brewing.</span>
        </h1>
        <p class="mt-8 text-lg md:text-xl max-w-xl leading-relaxed opacity-80">
          Meridian is a <strong class="font-medium">specialty coffee brand</strong> built for the curious palate — sourcing single-origin beans from the world's most distinctive growing regions and roasting them to reveal their truest character.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-6 text-sm">
          <a href="#waitlist" class="inline-flex items-center gap-2 bg-[color:var(--color-ember)] text-[color:var(--color-cream)] rounded-full px-7 py-3.5 uppercase tracking-[0.2em] hover:bg-[color:var(--color-ink)] transition">
            Join the Waitlist
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/about" class="underline underline-offset-4 hover:text-[color:var(--color-ember)] transition">Read our story →</a>
        </div>
      </div>

      <aside class="md:col-span-5 relative">
        <div class="aspect-[4/5] relative rounded-sm overflow-hidden bg-[color:var(--color-ink)]">
          <div class="absolute inset-0 opacity-90" style="background: radial-gradient(ellipse at 30% 20%, #3a2518 0%, #1a1411 60%, #0f0a08 100%);"></div>
          <svg viewBox="0 0 400 500" class="absolute inset-0 w-full h-full" aria-hidden="true">
            <defs>
              <radialGradient id="bean" cx="50%" cy="40%" r="70%">
                <stop offset="0%" stop-color="#8b5a32" stop-opacity="0.9"/>
                <stop offset="50%" stop-color="#5a3722" stop-opacity="0.9"/>
                <stop offset="100%" stop-color="#2c1810" stop-opacity="1"/>
              </radialGradient>
            </defs>
            <ellipse cx="200" cy="280" rx="110" ry="160" fill="url(#bean)" transform="rotate(-12 200 280)"/>
            <path d="M 200 130 Q 210 280 200 430" stroke="#1a0f08" stroke-width="3" fill="none" transform="rotate(-12 200 280)" opacity="0.9"/>
            <ellipse cx="200" cy="280" rx="110" ry="160" fill="none" stroke="#c7462a" stroke-width="0.5" transform="rotate(-12 200 280)" opacity="0.3"/>
          </svg>
          <div class="absolute bottom-6 left-6 right-6 text-[color:var(--color-cream)]">
            <p class="font-display italic text-2xl leading-tight">"Every cup has<br/>a coordinate."</p>
            <p class="mt-3 text-xs uppercase tracking-[0.3em] opacity-70">— Meridian Manifesto</p>
          </div>
          <div class="absolute top-6 right-6 text-[color:var(--color-cream)] text-right">
            <p class="text-[10px] uppercase tracking-[0.3em] opacity-60">N 4°42'</p>
            <p class="text-[10px] uppercase tracking-[0.3em] opacity-60">W 75°33'</p>
          </div>
        </div>
        <div class="absolute -top-3 -left-3 w-16 h-16 border border-[color:var(--color-ember)]/40 rounded-full hidden md:block"></div>
        <div class="absolute -bottom-3 -right-3 w-24 h-24 border border-current/10 rounded-full hidden md:block"></div>
      </aside>
    </div>
  </section>
</Base>
