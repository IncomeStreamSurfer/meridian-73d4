---
import Base from '../layouts/Base.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const title = 'Meridian | Specialty Coffee, Coming Soon';
const description = 'Meridian is a specialty coffee brand rooted in origin and craft. Join the waitlist for early access, exclusive drops, and stories from the source.';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://meridian-73d4.vercel.app';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Meridian',
    url: siteUrl,
    logo: `${siteUrl}/logo.svg`,
    description: 'A specialty coffee brand built for the curious palate — sourcing single-origin beans from the world’s most distinctive growing regions.',
    sameAs: []
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Meridian',
    url: siteUrl,
    description: 'Coffee at the Intersection of Origin and Craft'
  }
];

const pillars = [
  { tag: 'I.',   title: 'Origin-First Sourcing', body: 'We build relationships directly with producers in Colombia, Ethiopia, Kenya, Guatemala and beyond — buying lots that tell a specific story of place, elevation and process.' },
  { tag: 'II.',  title: 'Small-Batch Roasting',  body: 'Every lot is profiled individually. We roast in batches of 8kg on a heritage drum machine, pulling the curve when the bean’s sugars and acidity converge — not when a timer tells us to.' },
  { tag: 'III.', title: 'Transparent Everything',body: 'FOB price, farmer name, altitude, harvest date, cup score. Printed on every bag. What’s left unsaid in commodity coffee is what defines specialty coffee for us.' }
];
---
<Base
  title={title}
  description={description}
  structuredData={structuredData}
  tags={["specialty coffee brand","single origin coffee","craft coffee roaster","premium coffee beans","artisan coffee subscription"]}
>
  <section class="relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-10 pt-20 md:pt-28 pb-24 md:pb-32 grid md:grid-cols-12 gap-12 items-end">
      <div class="md:col-span-7 reveal-up">
        <p class="flex items-center gap-3 text-xs uppercase tracking-[0.4em] opacity-60 mb-8">
          <span class="w-8 h-px bg-current"></span>
          Est. Soon — Pre-launch
        </p>
        <h1 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl italic leading-[0.95] tracking-tight">
          Something
          <span class="block">exceptional</span>
          <span class="block">is brewing.</span>
        </h1>
        <p class="mt-8 text-lg md:text-xl max-w-xl leading-relaxed opacity-80">
          Meridian is a <strong class="font-medium">specialty coffee brand</strong> built for the curious palate — sourcing single-origin beans from the world's most distinctive growing regions and roasting them to reveal their truest character.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-6 text-sm">
          <a href="#waitlist" class="inline-flex items-center gap-2 bg-[color:var(--color-ember)] text-[color:var(--color-cream)] rounded-full px-7 py-3.5 uppercase tracking-[0.2em] hover:bg-[color:var(--color-ink)] transition">
            Join the Waitlist
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/about" class="underline underline-offset-4 hover:text-[color:var(--color-ember)] transition">Read our story →</a>
        </div>
      </div>

      <aside class="md:col-span-5 relative">
        <div class="aspect-[4/5] relative rounded-sm overflow-hidden bg-[color:var(--color-ink)]">
          <div class="absolute inset-0 opacity-90" style="background: radial-gradient(ellipse at 30% 20%, #3a2518 0%, #1a1411 60%, #0f0a08 100%);"></div>
          <svg viewBox="0 0 400 500" class="absolute inset-0 w-full h-full" aria-hidden="true">
            <defs>
              <radialGradient id="bean" cx="50%" cy="40%" r="70%">
                <stop offset="0%" stop-color="#8b5a32" stop-opacity="0.9"/>
                <stop offset="50%" stop-color="#5a3722" stop-opacity="0.9"/>
                <stop offset="100%" stop-color="#2c1810" stop-opacity="1"/>
              </radialGradient>
            </defs>
            <ellipse cx="200" cy="280" rx="110" ry="160" fill="url(#bean)" transform="rotate(-12 200 280)"/>
            <path d="M 200 130 Q 210 280 200 430" stroke="#1a0f08" stroke-width="3" fill="none" transform="rotate(-12 200 280)" opacity="0.9"/>
            <ellipse cx="200" cy="280" rx="110" ry="160" fill="none" stroke="#c7462a" stroke-width="0.5" transform="rotate(-12 200 280)" opacity="0.3"/>
          </svg>
          <div class="absolute bottom-6 left-6 right-6 text-[color:var(--color-cream)]">
            <p class="font-display italic text-2xl leading-tight">"Every cup has<br/>a coordinate."</p>
            <p class="mt-3 text-xs uppercase tracking-[0.3em] opacity-70">— Meridian Manifesto</p>
          </div>
          <div class="absolute top-6 right-6 text-[color:var(--color-cream)] text-right">
            <p class="text-[10px] uppercase tracking-[0.3em] opacity-60">N 4°42'</p>
            <p class="text-[10px] uppercase tracking-[0.3em] opacity-60">W 75°33'</p>
          </div>
        </div>
        <div class="absolute -top-3 -left-3 w-16 h-16 border border-[color:var(--color-ember)]/40 rounded-full hidden md:block"></div>
        <div class="absolute -bottom-3 -right-3 w-24 h-24 border border-current/10 rounded-full hidden md:block"></div>
      </aside>
    </div>

    <div class="border-y border-current/10 py-5 overflow-hidden">
      <div class="flex items-center gap-10 whitespace-nowrap font-display italic text-xl md:text-2xl opacity-60 animate-[marquee_40s_linear_infinite]">
        {Array.from({length: 3}).map(() => (
          <>
            <span>Single-origin</span>
            <span class="text-[color:var(--color-ember)]">—</span>
            <span>Small-batch roasted</span>
            <span class="text-[color:var(--color-ember)]">—</span>
            <span>Transparent sourcing</span>
            <span class="text-[color:var(--color-ember)]">—</span>
            <span>Traceable to the farm</span>
            <span class="text-[color:var(--color-ember)]">—</span>
          </>
        ))}
      </div>
    </div>
  </section>

  <section class="relative">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32 grid md:grid-cols-12 gap-12">
      <div class="md:col-span-4">
        <p class="text-xs uppercase tracking-[0.4em] opacity-60 mb-6">— 01 · The Idea</p>
        <h2 class="font-display text-4xl md:text-5xl italic leading-[1.05]">A brand shaped by where the bean grew.</h2>
      </div>
      <div class="md:col-span-7 md:col-start-6 space-y-6 text-lg leading-relaxed opacity-85">
        <p>Most coffee you drink is an average — a blend of many farms, many altitudes, many convictions, designed to taste the same in June as it does in December. That's a valid choice. It's just not ours.</p>
        <p>Meridian started with a simpler belief: that the place a bean is grown is the most interesting thing about it. A washed Gesha from the cloud forests of Huila doesn't taste like anything else in the world — and it shouldn't. Our job, as roasters, is to step out of the way.</p>
        <p>So we source single-origin lots directly from producers we trust. We roast in small batches on equipment that rewards patience. And we write down everything — altitude, variety, harvest, score — so the person pouring the cup knows exactly where it came from.</p>
        <p class="pt-2">
          <a href="/about" class="font-display italic text-xl underline underline-offset-4 decoration-[color:var(--color-ember)] hover:text-[color:var(--color-ember)] transition">Read the full story →</a>
        </p>
      </div>
    </div>
  </section>

  <section class="bg-[color:var(--color-ink)] text-[color:var(--color-cream)] relative grain">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32 relative z-10">
      <div class="max-w-2xl mb-16">
        <p class="text-xs uppercase tracking-[0.4em] opacity-60 mb-6">— 02 · What we believe</p>
        <h2 class="font-display text-4xl md:text-5xl italic leading-[1.05]">Three ideas, held with uncommon stubbornness.</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-10 md:gap-14">
        {pillars.map((p) => (
          <article class="group">
            <p class="font-display italic text-5xl text-[color:var(--color-ember)] mb-6">{p.tag}</p>
            <h3 class="font-display text-2xl md:text-3xl italic mb-4 leading-tight">{p.title}</h3>
            <p class="opacity-75 leading-relaxed">{p.body}</p>
            <div class="mt-6 w-10 h-px bg-current/30 group-hover:w-20 group-hover:bg-[color:var(--color-ember)] transition-all duration-500"></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="waitlist" class="relative scroll-mt-24">
    <div class="max-w-5xl mx-auto px-6 md:px-10 py-28 md:py-36 text-center">
      <p class="text-xs uppercase tracking-[0.4em] opacity-60 mb-8">— 03 · Reserve your seat</p>
      <h2 class="font-display text-5xl md:text-7xl italic leading-[1.02] tracking-tight">
        Be the first<br/>to <span class="text-[color:var(--color-ember)]">pour.</span>
      </h2>
      <p class="mt-8 text-lg md:text-xl max-w-xl mx-auto leading-relaxed opacity-80">
        Join the Meridian waitlist for early access to our launch lineup, origin dispatches from the road, and a founder's letter on the day we open the shop.
      </p>

      <div class="mt-12 flex justify-center">
        <WaitlistForm />
      </div>

      <div class="mt-14 flex flex-col sm:flex-row items-center justify-center gap-6 text-xs uppercase tracking-[0.3em] opacity-60">
        <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-ember)]"></span> Early Access</span>
        <span class="hidden sm:block">·</span>
        <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-ember)]"></span> Founder's Letter</span>
        <span class="hidden sm:block">·</span>
        <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-ember)]"></span> First-Pour Drops</span>
      </div>
    </div>
  </section>

  <section class="border-t border-current/10">
    <div class="max-w-4xl mx-auto px-6 md:px-10 py-20 md:py-28 text-center">
      <p class="font-display italic text-3xl md:text-4xl leading-[1.2]">
        "Great coffee doesn't need a speech.<br/>It needs a quiet room and a cup of the right size."
      </p>
      <p class="mt-6 text-xs uppercase tracking-[0.4em] opacity-60">— A note from the roastery</p>
    </div>
  </section>
</Base>

<style is:global>
  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }
</style>
